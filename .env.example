# University Portal Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# DATABASE
# ============================================
DB_NAME=university_portal
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_HOST=localhost
DB_PORT=5432

# ============================================
# DJANGO SECRET
# ============================================
DJANGO_SECRET_KEY=change_me_in_production_use_strong_random_key_here
DEBUG=False

# ============================================
# ALLOWED HOSTS
# ============================================
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# UNIVERSITY CONFIG
# ============================================
UNIVERSITY_NAME=University of Nigeria
UNIVERSITY_SHORT=UNN
ACADEMIC_STYLE=british_nigerian
SYSTEM_TYPE=university

# ============================================
# PAYMENT GATEWAYS (Nigerian)
# ============================================
REMITA_KEY=""
REMITA_SECRET=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""

# ============================================
# CENTRIFUGO (WebSocket)
# ============================================
CENTRIFUGO_SECRET=change_me_in_production
CENTRIFUGO_ADMIN_SECRET=change_me_in_production
CENTRIFUGO_URL=http://localhost:8000

# ============================================
# JAMB/CAPS INTEGRATION
# ============================================
CAPS_API_URL=https://caps.jamb.gov.ng
CAPS_API_KEY=""
JAMB_API_KEY=""

# ============================================
# TETFUND
# ============================================
TETFUND_API_KEY=""
TETFUND_INSTITUTION_ID=""

# ============================================
# EMAIL/SMS NOTIFICATIONS
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=""
EMAIL_HOST_PASSWORD=""
SMS_API_KEY=""
WHATSAPP_BUSINESS_ID=""

# ============================================
# AI/ML SERVICE
# ============================================
ML_SERVICE_URL=http://localhost:8002
OPENAI_API_KEY=""
LLAMA_MODEL_PATH=""

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# S3/CLOUD STORAGE (optional)
# ============================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_STORAGE_BUCKET_NAME=""
AWS_S3_REGION=us-east-1